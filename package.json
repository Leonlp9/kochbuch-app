{
  "name": "kochbuch-app",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "description": "Kochbuch – offline-faehige PWA/Android-App (Capacitor + Vue 3 + TypeScript)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "assets:android": "capacitor-assets generate --android",
    "cap:sync": "cap sync android && node scripts/patch-android.mjs",
    "cap:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/network": "^6.0.3",
    "@capgo/capacitor-updater": "^6.45.10",
    "@fontsource/fraunces": "^5.0.21",
    "@fontsource/work-sans": "^5.0.27",
    "@fortawesome/fontawesome-free": "^6.6.0",
    "idb-keyval": "^6.2.1",
    "jspdf": "^4.2.1",
    "pinia": "^2.2.2",
    "vue": "^3.4.38",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.1.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vue-tsc": "^2.0.29"
  }
}
